<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <xacro:include filename="$(find staubli_tx40_description)/urdf/common_materials.xacro"/>

  <xacro:macro name="staubli_tx40" params="prefix mesh_scale:='1 1 1'">
    <!-- links: main serial chain -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/visual/base_link.stl" scale="${mesh_scale}"/>
        </geometry>
        <xacro:material_staubli_ral_melon_yellow />
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/collision/base_link.stl" scale="${mesh_scale}"/>
        </geometry>
      </collision>
    </link>
    <link name="${prefix}link_1">
      <visual>
        <origin xyz="0 0 -0.168" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/visual/link_1.stl" scale="${mesh_scale}"/>
        </geometry>
        <xacro:material_staubli_ral_melon_yellow />
      </visual>
      <collision>
        <origin xyz="0 0 -0.168" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/collision/link_1.stl" scale="${mesh_scale}"/>
        </geometry>
      </collision>
    </link>
    <link name="${prefix}link_2">
      <visual>
        <origin xyz="0 0 -0.320" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/visual/link_2.stl" scale="${mesh_scale}"/>
        </geometry>
        <xacro:material_staubli_ral_melon_yellow />
      </visual>
      <collision>
        <origin xyz="0 0 -0.320" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/collision/link_2.stl" scale="${mesh_scale}"/>
        </geometry>
      </collision>
    </link>
    <link name="${prefix}link_3">
      <visual>
        <origin xyz="0 0 -0.545" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/visual/link_3.stl" scale="${mesh_scale}"/>
        </geometry>
        <xacro:material_staubli_ral_melon_yellow />
      </visual>
      <collision>
        <origin xyz="0 0 -0.545" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/collision/link_3.stl" scale="${mesh_scale}"/>
        </geometry>
      </collision>
    </link>
    <link name="${prefix}link_4">
      <visual>
        <origin xyz="0 -0.035 -0.545" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/visual/link_4.stl" scale="${mesh_scale}"/>
        </geometry>
        <xacro:material_staubli_ral_melon_yellow />
      </visual>
      <collision>
        <origin xyz="0 -0.035 -0.545" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/collision/link_4.stl" scale="${mesh_scale}"/>
        </geometry>
      </collision>
    </link>
    <link name="${prefix}link_5">
      <visual>
        <origin xyz="0 -0.035 -0.77" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/visual/link_5.stl" scale="${mesh_scale}"/>
        </geometry>
        <xacro:material_staubli_ral_grey_aluminium />
      </visual>
      <collision>
        <origin xyz="0 -0.035 -0.77" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/collision/link_5.stl" scale="${mesh_scale}"/>
        </geometry>
      </collision>
    </link>
    <link name="${prefix}link_6">
      <visual>
        <origin xyz="0 -0.035 -0.835" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/visual/link_6.stl" scale="${mesh_scale}"/>
        </geometry>
        <xacro:material_staubli_ral_grey_aluminium />
      </visual>
      <collision>
        <origin xyz="0 -0.035 -0.835" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://staubli_tx40_description/meshes/collision/link_6.stl" scale="${mesh_scale}"/>
        </geometry>
      </collision>
    </link>

    <!-- joints: main serial chain -->
    <joint name="${prefix}joint_1" type="revolute">
      <origin xyz="0 0 0.168" rpy="0 0 0"/> <!-- 0.168+0.0188 = 0.1868 -->
      <parent link="${prefix}base_link"/>
      <child link="${prefix}link_1"/>
      <axis xyz="0 0 1"/>
      <!-- from Staubli instruction manual:
      (1) effort limit = 126 Nm if floor mounted
      (2) effort limit = 40 Nm if wall mounted -->
      <!-- nominal velocity limits are used -->
      <limit lower="${radians(-180.0)}" upper="${radians(180.0)}" effort="126.0" velocity="${radians(555)}" />
    </joint>
    <joint name="${prefix}joint_2" type="revolute">
      <origin xyz="0 0 0.152" rpy="0 0 0"/>
      <parent link="${prefix}link_1"/>
      <child link="${prefix}link_2"/>
      <axis xyz="0 1 0"/>
      <!-- nominal velocity limits are used -->
      <limit lower="${radians(-125.0)}" upper="${radians(125.0)}" effort="47.0" velocity="${radians(475)}" />
    </joint>
    <joint name="${prefix}joint_3" type="revolute">
      <origin xyz="0 0 0.255" rpy="0 0 0"/>
      <parent link="${prefix}link_2"/>
      <child link="${prefix}link_3"/>
      <axis xyz="0 1 0"/>
      <!-- nominal velocity limits are used -->
      <limit lower="${radians(-138.0)}" upper="${radians(138.0)}" effort="32.0" velocity="${radians(585)}" />
    </joint>
    <joint name="${prefix}joint_4" type="revolute">
      <origin xyz="0 0.035 0" rpy="0 0 0"/>
      <parent link="${prefix}link_3"/>
      <child link="${prefix}link_4"/>
      <axis xyz="0 0 1"/>
      <!-- nominal velocity limits are used -->
      <limit lower="${radians(-270.0)}" upper="${radians(270.0)}" effort="7.0" velocity="${radians(1035)}" />
    </joint>
    <joint name="${prefix}joint_5" type="revolute">
      <origin xyz="0 0 0.225" rpy="0 0 0"/>
      <parent link="${prefix}link_4"/>
      <child link="${prefix}link_5"/>
      <axis xyz="0 1 0"/>
      <!-- nominal velocity limits are used -->
      <limit lower="${radians(-120.0)}" upper="${radians(133.5)}" effort="8.0" velocity="${radians(1135)}" />
    </joint>
    <joint name="${prefix}joint_6" type="revolute">
      <origin xyz="0 0 0.065" rpy="0 0 0"/>
      <parent link="${prefix}link_5"/>
      <child link="${prefix}link_6"/>
      <axis xyz="0 0 1"/>
      <!-- nominal velocity limits are used -->
      <limit lower="${radians(-270.0)}" upper="${radians(270.0)}" effort="2.0" velocity="${radians(1575)}" />
    </joint>

    <!-- ROS-Industrial 'base' frame: base_link to Staubli World Coordinates transform -->
    <link name="${prefix}base" />
    <joint name="${prefix}base_link-base" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}base"/>
    </joint>

    <!-- ROS-Industrial 'flange' frame: attachment point for EEF models -->
    <link name="${prefix}flange" />
    <joint name="${prefix}joint_6-flange" type="fixed">
      <origin xyz="0 0 0" rpy="0 ${radians(-90.0)} 0" />
      <parent link="${prefix}link_6" />
      <child link="${prefix}flange" />
    </joint>

    <!-- ROS-Industrial 'tool0' frame: all-zeros tool frame -->
    <link name="${prefix}tool0" />
    <joint name="${prefix}flange-tool0" type="fixed">
      <origin xyz="0 0 0" rpy="0 ${radians(90.0)} 0" />
      <parent link="${prefix}flange" />
      <child link="${prefix}tool0" />
    </joint>
  </xacro:macro>
</robot>
