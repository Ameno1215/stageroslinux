<?xml version="1.0" encoding="utf-8"?>
<Programs xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.staubli.com/robotics/VAL3/Program/2">
  <Program name="systemReceiver" access="public">
    <Locals>
      <Local name="l_bFlag" type="bool" xsi:type="array" size="1" />
      <Local name="l_bAckNeeded" type="bool" xsi:type="array" size="1" />
      <Local name="l_nDrivePower" type="num" xsi:type="array" size="1" />
      <Local name="l_nRetVal" type="num" xsi:type="array" size="1" />
    </Locals>
    <Code><![CDATA[begin
  // Handles Staubli-specific system requests from ROS on Socket\System.
  // Currently supported: SET_DRIVE_POWER (message type 1610).

  while(true)
    l_bAckNeeded=false

    call recvData(siTcpIpSystem,rosSystemMsg.prefix.nData,nSystemConnFlag,l_bFlag)
    if (l_bFlag == true)
      call recvData(siTcpIpSystem,rosSystemMsg.header.nData,nSystemConnFlag,l_bFlag)
    endIf

    if (l_bFlag == true)
      l_nRetVal=fromBinary(rosSystemMsg.prefix.nData,4,"-4l",rosSystemMsg.prefix.nLength)
      if (l_nRetVal!=1)
        l_bFlag=false
      endIf
    endIf

    if (l_bFlag == true)
      l_nRetVal=fromBinary(rosSystemMsg.header.nData,4,"-4l",rosSystemMsg.header.nMsgType)
      if (l_nRetVal!=1)
        l_bFlag=false
      endIf
    endIf

    if (l_bFlag == true)
      l_nRetVal=fromBinary(rosSystemMsg.header.nData[4],4,"-4l",rosSystemMsg.header.nCommType)
      if (l_nRetVal!=1)
        l_bFlag=false
      endIf
    endIf

    if (l_bFlag == true)
      l_nRetVal=fromBinary(rosSystemMsg.header.nData[8],4,"-4l",rosSystemMsg.header.nReplyCode)
      if (l_nRetVal!=1)
        l_bFlag=false
      endIf
    endIf

    if (l_bFlag == true)
      l_bAckNeeded=true
    endIf

    if (l_bFlag == true)
      // SET_DRIVE_POWER carries a one-byte bool body.
      if (rosSystemMsg.header.nMsgType==1610 and rosSystemMsg.prefix.nLength==13)
        call recvData(siTcpIpSystem,rosSystemBody.nData,nSystemConnFlag,l_bFlag)
      else
        l_bFlag=false
      endIf
    endIf

    // Default ACK is success; errors below flip it to failure.
    rosSysAckHeader.nReplyCode=1

    if (l_bFlag == true)
      l_nRetVal=fromBinary(rosSystemBody.nData,1,"1",l_nDrivePower)
      if (l_nRetVal==1)
        if (l_nDrivePower==1 and !isPowered())
          enablePower()
        elseIf (l_nDrivePower==0 and isPowered())
          disablePower()
        endIf
      else
        rosSysAckHeader.nReplyCode=2
      endIf
    elseIf (l_bAckNeeded)
      rosSysAckHeader.nReplyCode=2
    endIf

    if (l_bAckNeeded and nSystemConnFlag==1)
      call encPrefixHeader(rosSysAckPrefix,rosSysAckHeader)
      call sendRosMsg(siTcpIpSystem,rosSysAckPrefix,rosSysAckHeader,rosSysAckBody,nSystemConnFlag)
    endIf

    delay(0)
  endWhile
end]]></Code>
  </Program>
</Programs>
