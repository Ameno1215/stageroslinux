<?xml version="1.0" encoding="utf-8"?>
<Programs xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.staubli.com/robotics/VAL3/Program/2">
  <Program name="taskRecord">
    <Locals>
      <Local name="l_nAxis" type="num" xsi:type="array" size="1" />
      <Local name="l_nRecFrequency" type="num" xsi:type="array" size="1" />
      <Local name="l_nRecTime" type="num" xsi:type="array" size="1" />
      <Local name="l_nFileNumber" type="num" xsi:type="array" size="1" />
      <Local name="l_sFileName" type="string" xsi:type="array" size="1" />
      <Local name="l_sFileNumber" type="string" xsi:type="array" size="1" />
      <Local name="speed1" type="num" xsi:type="array" size="1" />
      <Local name="speed2" type="num" xsi:type="array" size="1" />
      <Local name="file" type="num" xsi:type="array" size="1" />
      <Local name="strLine" type="string" xsi:type="array" size="1" />
      <Local name="date" type="string" xsi:type="array" size="1" />
      <Local name="timems" type="num" xsi:type="array" size="1" />
      <Local name="pos" type="pointRx" xsi:type="array" size="1" />
    </Locals>
    <Code><![CDATA[begin
  
  //*******************************************************************************
  //*   ______
  //*  / _____) /|
  //* | |      / /
  //* | | /\  / /
  //* | | \ \/ /  _      Copyright (c) KEOLABS, 2016
  //* | |  \__/  | |        http://www.keolabs.com
