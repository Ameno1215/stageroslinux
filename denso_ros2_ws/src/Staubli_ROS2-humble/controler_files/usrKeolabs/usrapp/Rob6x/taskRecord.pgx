  //********************************************************************************
  //*@file          : taskRecord
  //*@author        : Yves Ragot
  //*@version       : $Id: taskRecord.pgx 1558 2017-01-05 08:13:36Z yves $
  //*@brief         : Execute recorder functions
  //*
  //*******************************************************************************/ 

  sPath = "Disk://autoRecord.csv"
  
if $fileExists(sPath)
    $delete(sPath)
endIf

do
    
  wait(bStartRecording)
  
  file = $fileOpen(sPath, "a")

  timems = 0
  while (bStartRecording)
    
      date = getDate("%y%m%d %H:%M:%S")
      speed1 = getSpeed(tCurrentTool)
      //speed2 = $getSpeedFbk(tCurrentTool)
      pos = here(tCurrentTool, fCurrentFrame)
    
    strLine = date + ";"  + toString("", timems) + ";" + toString(".3", speed1) + ";" + toString(".3", pos.trsf.z)
    if (file >= 0)
      $fileSet(file, strLine[0], 1)
    endIf
      
    timems = timems + 5
    delay(0.005)
    
  endWhile
  
  if (file >= 0)
    $fileClose(file)
  endIf
    
until(false)  
