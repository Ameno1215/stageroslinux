//  insert(CurLimitsTable["Zmin"])
//  CurLimitsTable["Zmin"] = -1000
//  insert(CurLimitsTable["Zmax"])
//  CurLimitsTable["Zmax"] = 1000
  
  // Global varaibles initialization
  bExit = false
  CartesianMode = true
  AlignMode = false
  AsyncMode = true
  //tCurrentTool = flange
  //currentToolType = 99
  call SetToolParam(0)
  fCurrentFrame = world
  LastErrorCode = 0
  GeneralStatus = 0
  MoveRunning = false
  bStartRecording = false
  
  // Default accleration and speed
  COEFF_ACCEL = 3
  mNomSpeed.vel = 20
  mNomSpeed.accel = 50
  mNomSpeed.decel = 50
    
end]]></Code>
