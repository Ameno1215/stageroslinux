  // creation limits table with default values
  insert(CurLimitsTable["Xmin"])
  CurLimitsTable["Xmin"] = -310
  insert(CurLimitsTable["Xmax"])
  CurLimitsTable["Xmax"] = 545
  insert(CurLimitsTable["Ymin"])
  CurLimitsTable["Ymin"] = -210
  insert(CurLimitsTable["Ymax"])
  CurLimitsTable["Ymax"] = 210
  insert(CurLimitsTable["Zmin"])
  CurLimitsTable["Zmin"] = -310
  insert(CurLimitsTable["Zmax"])
  CurLimitsTable["Zmax"] = 520
  
// for test  
//   insert(CurLimitsTable["Xmin"])
//  CurLimitsTable["Xmin"] = -1000
//  insert(CurLimitsTable["Xmax"])
//  CurLimitsTable["Xmax"] = 1000
