<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="denso_robot_control_limits" params="namespace">
    <joint name="$(arg namespace)joint_1">
      <command_interface name="position">
        <param name="min">-2.792527</param>
        <param name="max">2.792527</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">0</param>
        <param name="max">1</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="$(arg namespace)joint_2">
      <command_interface name="position">
        <param name="min">-2.094395</param>
        <param name="max">2.094395</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">0</param>
        <param name="max">1</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="$(arg namespace)joint_3">
      <command_interface name="position">
        <param name="min">-2.234021</param>
        <param name="max">2.373648</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">0</param>
        <param name="max">1</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">1.57</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="$(arg namespace)joint_4">
      <command_interface name="position">
        <param name="min">-2.792527</param>
        <param name="max">2.792527</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">0</param>
        <param name="max">1</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="$(arg namespace)joint_5">
      <command_interface name="position">
        <param name="min">-2.094395</param>
        <param name="max">2.094395</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">0</param>
        <param name="max">1</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">1.57</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="$(arg namespace)joint_6">
      <command_interface name="position">
        <param name="min">-6.283185</param>
        <param name="max">6.283185</param>
      </command_interface>
      <command_interface name="velocity">
        <param name="min">0</param>
        <param name="max">1</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </xacro:macro>
</robot>
